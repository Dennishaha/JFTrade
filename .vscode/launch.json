{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Dev Web",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "npm run dev:web",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Local:\\s+(https?://[^\\s]+)",
                "uriFormat": "%s"
            }
        },
        {
            "name": "Dev Docs",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "npm run dev:docs",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Local:\\s+(https?://[^\\s]+)",
                "uriFormat": "%s"
            }
        },
        {
            "name": "Dev Backend",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/jftrade-api",
            "args": [],
            "env": {
                "JFTRADE_SETTINGS_PATH": "${workspaceFolder}/var/jftrade-api/settings.json",
                "JFTRADE_BACKTEST_DB": "${workspaceFolder}/var/jftrade-api/backtest.db",
                "DISABLE_MARKETS_CACHE": "1"
            },
            "buildFlags": "-tags=embed_zoneinfo",
            "dlvFlags": [
                "--check-go-version=false"
            ]
        },
        {
            "name": "Dev Backend with PineTS Worker",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/jftrade-api",
            "args": [],
            "preLaunchTask": "build:pineworker:dev",
            "envFile": "${workspaceFolder}/var/pineworker/vscode.env",
            "env": {
                "JFTRADE_SETTINGS_PATH": "${workspaceFolder}/var/jftrade-api/settings.json",
                "JFTRADE_BACKTEST_DB": "${workspaceFolder}/var/jftrade-api/backtest.db",
                "JFTRADE_PINEWORKER_BACKTEST_WORKERS": "1",
                "JFTRADE_PINEWORKER_INSTANCE_WORKERS": "1",
                "DISABLE_MARKETS_CACHE": "1"
            },
            "buildFlags": "-tags=embed_zoneinfo",
            "dlvFlags": [
                "--check-go-version=false"
            ]
        },
        {
            "name": "Dev PineTS Worker API",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "npm run dev:api:pineworker"
        },
        {
            "name": "Dev Desktop (Wails)",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "npm run desktop:dev"
        }
    ]
}
