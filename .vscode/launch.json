{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Dev Web with Docs",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "npm run dev:docs",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Local:\\s+(https?://[^\\s]+)",
                "uriFormat": "%s"
            }
        },
        {
            "name": "Launch Backend",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/jftrade",
            "args": [
                "run",
                "--config",
                "${workspaceFolder}/config/jftrade.yaml"
            ],
            "env": {
                "JFTRADE_SETTINGS_PATH": "${workspaceFolder}/var/jftrade-api/settings.json",
                "JFTRADE_BACKTEST_DB": "${workspaceFolder}/var/jftrade-api/backtest.db",
                "DISABLE_MARKETS_CACHE": "1"
            },
            "buildFlags": "-tags=embed_zoneinfo",
            "dlvFlags": [
                "--check-go-version=false"
            ]
        }
    ]
}
