{
    // 使用 IntelliSense 了解相关属性。
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.0.0",
    "configurations": [
        {
            "name": "Dev Web (vite)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/apps/web",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Local:\\s+(https?://[^\\s]+)",
                "uriFormat": "%s"
            }
        },
        {
            "name": "Launch Full Backend (bbgo run)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/jftrade",
            "args": [
                "run",
                "--config",
                "${workspaceFolder}/config/jftrade.yaml"
            ],
            "env": {
                "JFTRADE_SETTINGS_PATH": "${workspaceFolder}/var/jftrade-api/settings.json",
                "JFTRADE_BACKTEST_DB": "${workspaceFolder}/var/jftrade-api/backtest.db",
                "DISABLE_MARKETS_CACHE": "1"
            },
            "buildFlags": "-tags=embed_zoneinfo"
        },
        {
            "name": "Launch API Server (dev)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/jftrade",
            "args": [
                "api"
            ],
            "env": {
                "JFTRADE_SETTINGS_PATH": "${workspaceFolder}/var/jftrade-api/settings.json",
                "JFTRADE_BACKTEST_DB": "${workspaceFolder}/var/jftrade-api/backtest.db",
                "DISABLE_MARKETS_CACHE": "1"
            },
            "buildFlags": "-tags=embed_zoneinfo"
        },
    ]
}