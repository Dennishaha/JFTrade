{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Web",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "npm run dev:web",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Local:\\s+(https?://[^\\s]+)",
                "uriFormat": "%s"
            }
        },
        {
            "name": "Debug Docs",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "npm run dev:docs",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Local:\\s+(https?://[^\\s]+)",
                "uriFormat": "%s"
            }
        },
        {
            "name": "Debug Web with Docs",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "npm run dev:all",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Local:\\s+(https?://[^\\s]+)",
                "uriFormat": "%s"
            }
        },
        {
            "name": "Debug Backend",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/jftrade-api",
            "args": [],
            "env": {
                "JFTRADE_SETTINGS_PATH": "${workspaceFolder}/var/jftrade-api/settings.json",
                "JFTRADE_BACKTEST_DB": "${workspaceFolder}/var/jftrade-api/backtest.db",
                "DISABLE_MARKETS_CACHE": "1"
            },
            "buildFlags": "-tags=embed_zoneinfo",
            "dlvFlags": [
                "--check-go-version=false"
            ]
        },
        {
            "name": "Build Web",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "npm run build:web"
        },
        {
            "name": "Build Docs",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "npm run build:docs"
        },
        {
            "name": "Build Backend",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "npm run build:backend"
        },
        {
            "name": "Build All",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "npm run build"
        }
    ]
}
