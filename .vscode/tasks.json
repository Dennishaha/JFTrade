{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "generate:docs",
            "type": "npm",
            "script": "generate:docs",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "showReuseMessage": true,
                "close": false
            }
        },
        {
            "label": "go:fix",
            "type": "shell",
            "command": "go fix ./...",
            "group": "build",
            "problemMatcher": [
                "$go"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "showReuseMessage": true,
                "close": false
            }
        },
        {
            "label": "go:vet",
            "type": "shell",
            "command": "go vet ./...",
            "group": "build",
            "problemMatcher": [
                "$go"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "showReuseMessage": true,
                "close": false
            }
        },
        {
            "label": "go:lint",
            "type": "shell",
            "command": "${env:HOME}/go/bin/golangci-lint",
            "args": [
                "run",
                "--timeout=5m"
            ],
            "group": "test",
            "problemMatcher": [
                "$go"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "showReuseMessage": true,
                "close": false
            }
        },
        {
            "label": "build:web",
            "type": "npm",
            "script": "build:web",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "test:web",
            "type": "npm",
            "script": "test:web",
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "typecheck:web",
            "type": "npm",
            "script": "typecheck:web",
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "ci:web-local",
            "dependsOrder": "sequence",
            "dependsOn": [
                "generate:docs",
                "go:lint",
                "test:web",
                "typecheck:web"
            ],
            "group": "test",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "showReuseMessage": true,
                "close": false
            }
        },
        {
            "label": "build:docs",
            "type": "npm",
            "script": "build:docs",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "build:backend",
            "type": "npm",
            "script": "build:backend",
            "group": "build",
            "problemMatcher": ["$go"]
        },
        {
            "label": "build:pineworker:dev",
            "type": "shell",
            "command": "npm",
            "args": ["run", "build:pineworker:dev"],
            "options": {
                "env": {
                    "JFTRADE_PINEWORKER_DEV_ENV_FILE": "${workspaceFolder}/var/pineworker/vscode.env"
                }
            },
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "showReuseMessage": true,
                "close": false
            }
        },
        {
            "label": "build:all",
            "type": "npm",
            "script": "build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
