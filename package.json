{
  "name": "@jftrade/root",
  "private": true,
  "engines": {
    "node": ">=24",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.7",
  "version": "0.0.0",
  "workspaces": [
    "apps/web",
    "workers/pineworker"
  ],
  "overrides": {
    "vue": "3.5.38"
  },
  "scripts": {
    "dev:web": "npm -w @jftrade/web run dev",
    "dev:docs": "vitepress dev docs --host 127.0.0.1 --port 3001",
    "dev:all": "node scripts/dev-all.mjs",
    "build": "npm run build:web && npm run build:docs && npm run build:backend",
    "build:web": "npm -w @jftrade/web run build",
    "build:docs": "npm run generate:docs && vitepress build docs",
    "build:backend": "go build -tags=embed_zoneinfo -o dist/jftrade-dev ./cmd/jftrade-api",
    "build:frontend-assets": "bash scripts/build-frontend-assets.sh",
    "build:pineworker": "bash scripts/build-pineworker-assets.sh",
    "build:pineworker:dev": "bash scripts/build-pineworker-dev.sh",
    "dev:api:pineworker": "JFTRADE_PINEWORKER_BINARY=$(bash scripts/build-pineworker-dev.sh | tail -n 1) go run ./cmd/jftrade-api",
    "check:pinets-release": "bash scripts/check-pinets-release.sh",
    "test:pinets-release-check": "bash scripts/check-pinets-release.test.sh",
    "test:pineworker-asset-build": "bash scripts/build-pineworker-assets.test.sh",
    "test:web": "npm -w @jftrade/web run test",
    "test:web:watch": "npm -w @jftrade/web run test:watch",
    "test:pineworker": "node scripts/run-bun.mjs test workers/pineworker/src",
    "typecheck:web": "npm -w @jftrade/web run typecheck",
    "typecheck:pineworker": "npx tsc --noEmit -p workers/pineworker/tsconfig.json",
    "generate:openapi": "go generate ./cmd/jftrade-api",
    "generate:reference": "node scripts/generate-docs.mjs",
    "generate:docs": "npm run generate:openapi && npm run generate:reference",
    "stage:docs": "node scripts/stage-docs.mjs",
    "check:pinets-license": "node scripts/check-pinets-license.mjs",
    "typecheck": "npm run typecheck:web && npm run typecheck:pineworker"
  },
  "dependencies": {
    "pinets": "0.9.26",
    "vitepress": "1.6.4"
  },
  "devDependencies": {
    "typedoc": "0.28.19"
  }
}
