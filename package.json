{
  "name": "@jftrade/root",
  "private": true,
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.12.0",
  "version": "0.0.0",
  "scripts": {
    "audit:dependencies": "pnpm audit --audit-level=moderate",
    "dev:web": "pnpm --filter @jftrade/web run dev",
    "dev:docs": "pnpm --filter @jftrade/web run docs:dev",
    "dev:all": "node scripts/dev-all.mjs",
    "desktop:dev": "node scripts/wails3.mjs task desktop:dev",
    "desktop:doctor": "node scripts/wails3.mjs doctor",
    "desktop:build": "node scripts/wails3.mjs task desktop:build",
    "desktop:build:darwin-arm64": "node scripts/wails3.mjs task desktop:build:darwin-arm64",
    "desktop:build:windows": "node scripts/wails3.mjs task desktop:build:windows",
    "desktop:build:windows-arm64": "node scripts/wails3.mjs task desktop:build:windows-arm64",
    "desktop:build:linux": "node scripts/wails3.mjs task desktop:build:linux",
    "desktop:release": "node scripts/wails3.mjs task desktop:release",
    "desktop:release:darwin": "node scripts/wails3.mjs task desktop:release:darwin",
    "desktop:release:windows": "node scripts/wails3.mjs task desktop:release:windows",
    "desktop:release:windows-arm64": "node scripts/wails3.mjs task desktop:release:windows-arm64",
    "desktop:release:linux": "node scripts/wails3.mjs task desktop:release:linux",
    "desktop:package:windows-msix": "node scripts/wails3.mjs task desktop:package:windows-msix",
    "desktop:package:linux-appimage": "node scripts/wails3.mjs task desktop:package:linux-appimage",
    "desktop:package:linux-deb": "node scripts/wails3.mjs task desktop:package:linux-deb",
    "desktop:package:linux-rpm": "node scripts/wails3.mjs task desktop:package:linux-rpm",
    "desktop:package:linux-arch": "node scripts/wails3.mjs task desktop:package:linux-arch",
    "build": "pnpm run build:web && pnpm run build:docs && pnpm run build:backend",
    "build:web": "pnpm --filter @jftrade/web run build",
    "build:docs": "pnpm run generate:docs && pnpm --filter @jftrade/web run docs:build",
    "build:backend": "go build -tags=embed_zoneinfo -o dist/jftrade-dev ./cmd/jftrade-api",
    "prepare:desktop-release": "pnpm run generate:docs && pnpm run build:frontend-assets",
    "build:frontend-assets": "node scripts/build-frontend-assets.mjs",
    "build:pineworker": "node scripts/build-pineworker-assets.mjs",
    "build:pineworker:dev": "node scripts/build-pineworker-dev.mjs",
    "dev:api:pineworker": "node scripts/dev-api-pineworker.mjs",
    "check:pinets-release": "node scripts/check-pinets-release.mjs",
    "check:arch-deps": "bash scripts/check-arch-deps.sh",
    "test:pinets-release-check": "node scripts/check-pinets-release.test.mjs",
    "test:pineworker-asset-build": "node scripts/build-pineworker-assets.test.mjs",
    "test:pineworker-dev-build": "node scripts/build-pineworker-dev.test.mjs",
    "test:pinets-shadow-corpus": "go test ./pkg/backtest -run TestPinetsShadowCorpusReport -count=1 -v",
    "smoke:pinets-backtest": "node scripts/smoke-pinets-backtest.mjs",
    "lint:go": "go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.12.0 run --timeout=5m --build-tags=gtk3",
    "vet:go": "go vet ./...",
    "test:go": "go test ./... -count=1 -timeout 300s",
    "test:servercore": "go test ./internal/app/apiserver/servercore -count=1 -timeout 120s",
    "test:web": "pnpm --filter @jftrade/web run test",
    "test:web:ci": "pnpm --filter @jftrade/web run test:ci",
    "test:web:watch": "pnpm --filter @jftrade/web run test:watch",
    "test:coverage": "pnpm run test:coverage:go && pnpm run test:coverage:web",
    "test:coverage:go": "go run ./cmd/check-go-coverage",
    "test:coverage:web": "pnpm --filter @jftrade/web run test --coverage",
    "test:pineworker": "pnpm --filter @jftrade/pineworker run test",
    "typecheck:web": "pnpm --filter @jftrade/web run typecheck",
    "typecheck:pineworker": "pnpm --filter @jftrade/pineworker run typecheck",
    "generate:openapi": "go generate ./cmd/jftrade-api",
    "generate:reference": "node scripts/generate-docs.mjs",
    "generate:docs": "pnpm run generate:openapi && pnpm run generate:reference",
    "generate:api-types": "node scripts/generate-api-types.mjs",
    "generate:wails-bindings": "node scripts/wails3.mjs generate bindings -ts -i -noevents -d apps/web/src/wails ./cmd/jftrade-desktop",
    "check:wails-bindings": "node scripts/check-wails-bindings.mjs",
    "test:desktop-release-metadata": "node scripts/lib/desktop-release-metadata.test.mjs",
    "test:desktop-release-inputs": "node scripts/lib/desktop-release-inputs.test.mjs",
    "test:desktop-wails-tasks": "node scripts/desktop-wails-tasks.test.mjs",
    "test:desktop-signing": "node scripts/sign-desktop-release.test.mjs",
    "test:desktop-linux-package-config": "node scripts/prepare-linux-package-config.test.mjs",
    "test:api-release-scripts": "node scripts/api-release-scripts.test.mjs",
    "test:desktop": "pnpm run prepare:desktop-release && pnpm run check:wails-bindings && pnpm run test:desktop-release-metadata && pnpm run test:desktop-release-inputs && pnpm run test:desktop-wails-tasks && pnpm run test:desktop-signing && pnpm run test:desktop-linux-package-config && node scripts/dev-desktop.test.mjs && go test -tags production,release_assets ./cmd/jftrade-desktop ./internal/desktop -count=1",
    "check:desktop": "pnpm run desktop:doctor && pnpm run test:desktop",
    "stage:docs": "node scripts/stage-docs.mjs",
    "check:pinets-compliance": "node scripts/check-pinets-compliance.mjs",
    "check:pinets-license": "node scripts/check-pinets-license.mjs",
    "typecheck": "pnpm run typecheck:web && pnpm run typecheck:pineworker"
  },
  "devDependencies": {
    "mermaid": "^11.16.0",
    "typescript": "^6.0.3",
    "vitepress": "2.0.0-alpha.18",
    "vue": "catalog:"
  }
}
