{
  "name": "@jftrade/root",
  "private": true,
  "engines": {
    "node": ">=24",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.7",
  "version": "0.0.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --workspace @jftrade/web run dev",
    "build:web": "npm --workspace @jftrade/web run build",
    "dev:docs": "npm run generate:docs && node scripts/dev-docs.mjs",
    "generate:openapi": "go generate ./cmd/jftrade-api",
    "generate:docs": "npm run generate:openapi && node scripts/generate-docs.mjs",
    "build:docs": "npm run generate:docs && vitepress build docs",
    "stage:docs": "node scripts/stage-docs.mjs",
    "typecheck": "npm --workspace @jftrade/web run typecheck"
  },
  "dependencies": {
    "vitepress": "1.6.4"
  },
  "devDependencies": {
    "typedoc": "0.28.19"
  }
}
