{
  "name": "@jftrade/root",
  "private": true,
  "packageManager": "npm@10.9.7",
  "version": "0.0.0",
  "workspaces": [
    "apps/web",
    "packages/ui-contracts"
  ],
  "scripts": {
    "dev:web": "npm --workspace @jftrade/web run dev",
    "build:web": "npm --workspace @jftrade/web run build",
    "dev:docs": "node scripts/dev-docs.mjs",
    "generate:docs": "node scripts/generate-docs.mjs",
    "build:docs": "npm run generate:docs && vitepress build docs",
    "stage:docs": "node scripts/stage-docs.mjs",
    "typecheck": "npm --workspace @jftrade/web run typecheck"
  },
  "devDependencies": {
    "typedoc": "0.28.19",
    "vitepress": "1.6.4"
  }
}
