{
  "name": "@jftrade/web",
  "private": true,
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.7",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
