    "mermaid": "^11.16.0",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.4",
    "splitpanes": "^4.1.2",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vuetify": "4.1.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "typedoc": "0.28.19",
