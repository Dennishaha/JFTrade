# Dev frontend uses Vite's same-origin proxy by default:
#   http://127.0.0.1:3003/api/* -> http://127.0.0.1:3000/api/*
#
# Leave VITE_API_BASE_URL empty in development unless you intentionally want
# browser requests to bypass the Vite proxy.
VITE_API_BASE_URL=

# Optional: override the Vite proxy target when the sidecar is not on :3000.
# Example (JFTrade Dev desktop sidecar):
# VITE_DEV_API_TARGET=http://127.0.0.1:3008
VITE_DEV_API_TARGET=
